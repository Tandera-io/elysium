# Meshy.ai — https://meshy.ai (API key starts with msy_)
MESHY_API_KEY=msy_XXXXXXXXXXXXXXXX

# Anthropic — https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-XXXXXXXXXXXXXXXX

# Default model for NPC dialogue (Haiku is fast + cheap)
NPC_LLM_MODEL=claude-haiku-4-5-20251001

# Reserve Sonnet for key moments (first encounter, critical events)
NPC_LLM_MODEL_PREMIUM=claude-sonnet-4-6

# Backend server port (client proxies /api here)
PORT=3001

# NOTE: If this elysium/.env does not exist, the server falls back to ../.env
# (the NGS 2.0 root .env). See docs/obsidian/50-decisions/ADR-0002-env-resolution.md
