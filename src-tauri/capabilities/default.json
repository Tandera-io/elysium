{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "default capabilities for Elysium Build Platform",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:window:allow-start-dragging",
    "core:webview:default",
    "core:event:default",
    "shell:default",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "claude",
          "cmd": "claude",
          "args": true,
          "sidecar": false
        },
        {
          "name": "git",
          "cmd": "git",
          "args": true,
          "sidecar": false
        },
        {
          "name": "godot",
          "cmd": "godot",
          "args": true,
          "sidecar": false
        },
        {
          "name": "godot.exe",
          "cmd": "godot.exe",
          "args": true,
          "sidecar": false
        },
        {
          "name": "dotnet",
          "cmd": "dotnet",
          "args": true,
          "sidecar": false
        },
        {
          "name": "dotnet.exe",
          "cmd": "dotnet.exe",
          "args": true,
          "sidecar": false
        }
      ]
    },
    "fs:default",
    "fs:allow-appdata-read-recursive",
    "fs:allow-appdata-write-recursive",
    "fs:allow-appdata-meta-recursive",
    "fs:allow-appconfig-read-recursive",
    "fs:allow-appconfig-write-recursive",
    "dialog:default",
    "http:default",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "https://api.pixellab.ai/*" },
        { "url": "https://api.elevenlabs.io/*" },
        { "url": "https://api.anthropic.com/*" },
        { "url": "https://api.openai.com/*" }
      ]
    },
    "sql:default",
    "sql:allow-load",
    "sql:allow-execute",
    "sql:allow-select",
    "sql:allow-close"
  ]
}
